# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1                        # Planning + code generation (32 768 output tokens)
OPENAI_PARSER_MODEL=gpt-4.1-mini            # Code parsing (higher TPM limit, lower cost)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM defaults
# LLM_MAX_TOKENS  — max output tokens for the Planner and Reviewer agents
LLM_MAX_TOKENS=4096
# GENERATOR_MAX_TOKENS — max output tokens reserved for the Code Generator agent.
# Needs to be large enough to fit a full Nest.js module in one response.
# gpt-4o hard cap: 16 384  |  gpt-4.1 hard cap: 32 768
GENERATOR_MAX_TOKENS=16000
LLM_TEMPERATURE=0.2

# PostgreSQL + pgvector (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legacy_architect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
EMBEDDING_DIMENSIONS=1536

# Application
WORKSPACE_DIR=./workspace
OUTPUT_DIR=./output
MAX_RETRIES=3
CONTEXT_TOKEN_BUDGET=12000
PARSE_CONCURRENCY=10
